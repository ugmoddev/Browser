<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="@android:color/transparent"/>
            <corners android:radius="@dimen/bm"/>
            <stroke
                android:width="@dimen/t"
                android:color="@android:color/black"/>
        </shape>
    </item>
    <item>
        <inset
            android:insetTop="@dimen/r"
            android:insetBottom="0dp">
            <shape>
                <solid android:color="@android:color/transparent"/>
                <corners
                    android:bottomLeftRadius="@dimen/bm"
                    android:bottomRightRadius="@dimen/bm"/>
                <stroke
                    android:width="@dimen/t"
                    android:color="@android:color/black"/>
            </shape>
        </inset>
    </item>
</layer-list>
