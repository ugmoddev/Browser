<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:scrollbars="none"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_horizontal"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/cx"
            android:contentDescription="@string/c_"/>
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <TextView
            android:textSize="@dimen/a9"
            android:textColor="?attr/ac"
            android:layout_gravity="center_horizontal"
            android:id="@+id/fh"
            android:nextFocusDown="@+id/ek"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/a0z"
            android:textDirection="locale"/>
        <TextView
            android:textSize="@dimen/a_"
            android:textColor="?attr/ac"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/ek"
            android:nextFocusUp="@+id/fh"
            android:nextFocusDown="@+id/ei"
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:lineSpacingMultiplier="1.2"
            android:textDirection="locale"/>
        <TextView
            android:textSize="@dimen/a_"
            android:textColor="?attr/a_"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/ei"
            android:paddingLeft="16dp"
            android:paddingTop="12dp"
            android:paddingRight="16dp"
            android:paddingBottom="12dp"
            android:nextFocusUp="@+id/ek"
            android:nextFocusDown="@+id/es"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:minWidth="216dp"
            android:text="@string/bp"
            android:lines="1"/>
        <TextView
            android:textSize="@dimen/a_"
            android:textColor="?attr/ad"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/es"
            android:background="@drawable/o"
            android:paddingLeft="16dp"
            android:paddingTop="8dp"
            android:paddingRight="16dp"
            android:paddingBottom="8dp"
            android:nextFocusUp="@+id/ei"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minWidth="80dp"
            android:text="@string/ga"/>
    </LinearLayout>
</ScrollView>
