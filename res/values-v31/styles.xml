<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="m" parent="@android:style/Theme.DeviceDefault.Light">
        <item name="android:statusBarColor">@color/h</item>
        <item name="android:navigationBarColor">@color/h</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:navigationBarDividerColor">@android:color/transparent</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:isLightTheme">true</item>
    </style>
    <style name="aa" parent="@android:style/Theme.DeviceDefault">
        <item name="android:statusBarColor">@color/i</item>
        <item name="android:navigationBarColor">@color/i</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:navigationBarDividerColor">@android:color/transparent</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:isLightTheme">false</item>
    </style>
</resources>
